{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run all tests",
            "type": "shell",
            "command": "source /home/parallels/venv/fpga/bin/activate && pytest tests/ -v",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Run all tests (verbose)",
            "type": "shell",
            "command": "source /home/parallels/venv/fpga/bin/activate && pytest tests/ -v -s",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Run single test",
            "type": "shell",
            "command": "source /home/parallels/venv/fpga/bin/activate && pytest tests/test_${input:moduleName}.py -v",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Run single test verbose",
            "type": "shell",
            "command": "source /home/parallels/venv/fpga/bin/activate && pytest tests/test_${input:moduleName}.py -v -s",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Run single test (clean build)",
            "type": "shell",
            "command": "source /home/parallels/venv/fpga/bin/activate && rm -rf sim_build && pytest tests/test_${input:moduleName}.py -v -s",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ],
    "inputs": [
        {
            "id": "moduleName",
            "type": "command",
            "command": "shellCommand.execute",
            "args": {
                "command": "ls tests/test_*.py | sed 's|tests/test_||' | sed 's|\\.py||' | sort",
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}