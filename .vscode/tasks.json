{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run all tests",
            "type": "shell",
            "command": "source /home/parallels/venv/fpga/bin/activate && pytest tests/ -v",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Run all tests (verbose)",
            "type": "shell",
            "command": "source /home/parallels/venv/fpga/bin/activate && pytest tests/ -v -s",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Run single test",
            "type": "shell",
            "command": "source /home/parallels/venv/fpga/bin/activate && pytest tests/test_${input:toplevel}.py -v -s",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ],
    "inputs": [
        {
            "id": "toplevel",
            "type": "promptString",
            "description": "Module to test",
            "default": "nand_gate"
        }
    ]
}