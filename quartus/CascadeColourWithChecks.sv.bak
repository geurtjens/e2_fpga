// ─────────────────────────────────────────────────────────────
// CascadeColourWithChecks
//
// Composes three modules in sequence:
//   1. CascadeColoursSimple  — compute cascade AND results
//   2. CascadeColourDeadend  — check if any edge went to zero
//   3. ChangeInColours       — check if any edge value changed
//
// This makes the circuit structure explicit and each stage
// visible as a separate block in RTL Viewer.
// ─────────────────────────────────────────────────────────────
module CascadeColoursWithChecks #(
    parameter int N  = 4,
    parameter int TC = 6
)(
    input  logic [N*N-1:0][TC-1:0] in_top,
    input  logic [N*N-1:0][TC-1:0] in_right,
    input  logic [N*N-1:0][TC-1:0] in_bottom,
    input  logic [N*N-1:0][TC-1:0] in_left,
    output logic [N*N-1:0][TC-1:0] out_top,
    output logic [N*N-1:0][TC-1:0] out_right,
    output logic [N*N-1:0][TC-1:0] out_bottom,
    output logic [N*N-1:0][TC-1:0] out_left,
    output logic                   deadend,
    output logic                   changed
);

    // ── Stage 1 — cascade ──────────────────────────────────────
    CascadeColoursSimple #(.N(N), .TC(TC)) u_cascade (
        .in_top    (in_top),
        .in_right  (in_right),
        .in_bottom (in_bottom),
        .in_left   (in_left),
        .out_top   (out_top),
        .out_right (out_right),
        .out_bottom(out_bottom),
        .out_left  (out_left)
    );

    // ── Stage 2 — deadend detection ────────────────────────────
    CascadeColourDeadend #(.N(N), .TC(TC)) u_deadend (
        .out_right (out_right),
        .out_bottom(out_bottom),
        .deadend   (deadend)
    );

    // ── Stage 3 — change detection ─────────────────────────────
    ChangeInColours #(.N(N), .TC(TC)) u_changed (
        .in_top    (in_top),
        .in_right  (in_right),
        .in_bottom (in_bottom),
        .in_left   (in_left),
        .out_top   (out_top),
        .out_right (out_right),
        .out_bottom(out_bottom),
        .out_left  (out_left),
        .changed   (changed)
    );

endmodule
